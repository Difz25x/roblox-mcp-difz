{
  "name": "roblox-mcp-difz",
  "version": "1.2.5",
  "description": "Universal MCP server for Roblox game control, reverse engineering, and exploitation — supports Claude Code, Claude Desktop, Cursor, Windsurf, and any MCP-compatible AI.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "roblox-mcp-difz": "bin/roblox-mcp",
    "rblx-mcp": "bin/roblox-mcp"
  },
  "scripts": {
    "start": "node bin/roblox-mcp start",
    "setup": "node bin/roblox-mcp setup",
    "build": "tsc",
    "publish": "node publish.mjs",
    "publish:force": "node publish.mjs --force",
    "publish:dry": "node publish.mjs --dry-run",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "public/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "roblox",
    "mcp",
    "model-context-protocol",
    "reverse-engineering",
    "game-hacking",
    "claude-code",
    "exploit"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "uuid": "^11.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Difz25x/roblox-mcp-difz.git"
  },
  "bugs": {
    "url": "https://github.com/Difz25x/roblox-mcp-difz/issues"
  },
  "homepage": "https://github.com/Difz25x/roblox-mcp-difz#readme",
  "author": "Difz25x"
}
